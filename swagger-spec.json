    "securitySchemes": {
      "JWT-auth": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http",
        "name": "JWT",
        "description": "Nhập mã token vào đây",
        "in": "header"
      }
    },
    "schemas": {
      "CreateSiteDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "example": "Kênh Tin Tức ABC",
            "description": "Tiêu đề hoặc tên của trang web"
          },
          "description": {
            "type": "string",
            "example": "Trang web cập nhật tin tức công nghệ 24/7",
            "description": "Mô tả ngắn gọn về trang web"
          },
          "linkPhoto": {
            "type": "string",
            "example": "https://example.com",
            "description": "Đường dẫn liên kết hình ảnh của trang web"
          },
          "updatedBy": {
            "type": "string",
            "example": "64f1a2b3c4d5e6f7a8b9c0d1",
            "description": "ID người dùng thực hiện cập nhật hệ thống (MongoDB ObjectId)"
          }
        },
        "required": [
          "title"
        ]
      },
      "SiteResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "64f1a2b3c4d5e6f7a8b9c0d1"
          },
          "title": {
            "type": "string",
            "example": "Kênh Tin Tức ABC"
          }
        },
        "required": [
          "id",
          "title"
        ]
      },
      "UpdateSiteDto": {
        "type": "object",
        "properties": {}
      },
      "VariableDefinitionDto": {
        "type": "object",
        "properties": {
          "key": {
            "type": "string",
            "example": "siteUrl"
          },
          "label": {
            "type": "string",
            "example": "Đường dẫn đài"
          },
          "type": {
            "type": "string",
            "example": "TEXT",
            "enum": [
              "TEXT",
              "NUMBER",
              "SELECT"
            ]
          },
          "options": {
            "example": [],
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "placeholder": {
            "type": "string",
            "example": "Nhập URL..."
          }
        },
        "required": [
          "key",
          "label",
          "type",
          "options",
          "placeholder"
        ]
      },
      "WorkflowStepDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "1"
          },
          "action": {
            "type": "string",
            "example": "GOTO"
          },
          "description": {
            "type": "string",
            "example": "Truy cập trang chủ"
          }
        },
        "required": [
          "id",
          "action",
          "description"
        ]
      },
      "CreateTemplateDto": {
        "type": "object",
        "properties": {
          "taskType": {
            "type": "string",
            "example": "MOMO_PORTAL_CHECK"
          },
          "slug": {
            "type": "string",
            "example": "momo-da-tab-by-dev-alpha"
          },
          "name": {
            "type": "string",
            "example": "Mẫu kiểm tra cổng nạp Đa Tab"
          },
          "imageUrl": {
            "type": "string",
            "example": "https://media.licdn.com/..."
          },
          "engine": {
            "type": "string",
            "example": "PLAYWRIGHT",
            "enum": [
              "PLAYWRIGHT",
              "AXIOS_HTTP"
            ]
          },
          "variableDefinitions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/VariableDefinitionDto"
            }
          },
          "baseWorkflow": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/WorkflowStepDto"
            }
          },
          "authorId": {
            "type": "string",
            "example": "64f1a2b3c4d5e6f7a8b9c0d1"
          },
          "isActive": {
            "type": "boolean",
            "example": true
          }
        },
        "required": [
          "taskType",
          "slug",
          "name",
          "engine",
          "variableDefinitions",
          "baseWorkflow",
          "authorId"
        ]
      },
      "TemplateResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
