          },
          "name": {
            "type": "string",
            "example": "Mẫu kiểm tra cổng nạp Đa Tab"
          },
          "engine": {
            "type": "string",
            "example": "PLAYWRIGHT"
          },
          "version": {
            "type": "number",
            "example": 1,
            "description": "Phiên bản hiện tại của kịch bản gốc"
          },
          "authorId": {
            "type": "string",
            "example": "64f1a2b3c4d5e6f7a8b9c0d1"
          }
        },
        "required": [
          "id",
